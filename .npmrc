# .npmrc configuration to help with installation issues

# Use legacy peer dependency resolution
legacy-peer-deps=true

# Increase network timeout
fetch-timeout=300000
fetch-retries=5

# Use official npm registry
registry=https://registry.npmjs.org/

# Disable strict SSL if behind corporate proxy (comment out if not needed)
# strict-ssl=false

# Engine strict mode
engine-strict=false
