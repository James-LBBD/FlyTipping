# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_GPT4_VISION_DEPLOYMENT=gpt-4-vision
AZURE_OPENAI_GPT4_DEPLOYMENT=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure Authentication
# For local development: Use Azure CLI (az login)
# For production: Managed Identity will be used automatically
# AZURE_TENANT_ID=your-tenant-id (optional, for DefaultAzureCredential)
# AZURE_CLIENT_ID=your-client-id (optional, for user-assigned MI)
